{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],

    "types": ["node"],

    "strict": true,

    "sourceMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "isolatedModules": true,
    "moduleDetection": "force",
    "verbatimModuleSyntax": false,

    "skipLibCheck": true
  },
  "exclude": [
    "prisma.config.ts"
  ]
}
